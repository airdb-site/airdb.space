---
// 轻量 Canvas 星空：缓慢漂移 + 呼吸式闪烁，prefers-reduced-motion 时静态渲染一帧
---

<canvas id="starfield" class="absolute inset-0 h-full w-full" aria-hidden="true"
></canvas>

<script>
  const canvas = document.getElementById('starfield') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  interface Star {
    x: number;
    y: number;
    r: number;
    base: number; // 基础亮度
    phase: number; // 闪烁相位
    speed: number; // 漂移速度
  }

  let stars: Star[] = [];
  let w = 0;
  let h = 0;
  let dpr = 1;

  function setup() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = canvas.clientWidth;
    h = canvas.clientHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const count = Math.min(Math.floor((w * h) / 5200), 320);
    stars = Array.from({ length: count }, () => ({
      x: Math.random() * w,
      y: Math.random() * h,
      r: Math.random() < 0.88 ? Math.random() * 0.9 + 0.3 : Math.random() * 1.5 + 1,
      base: Math.random() * 0.55 + 0.25,
      phase: Math.random() * Math.PI * 2,
      speed: Math.random() * 0.016 + 0.004,
    }));
  }

  // 偶发流星：8–20 秒一颗，短暂划过
  interface Meteor {
    x: number;
    y: number;
    vx: number;
    vy: number;
    life: number; // 0 → 1
  }
  let meteor: Meteor | null = null;
  let nextMeteorAt = 4000 + Math.random() * 8000;

  function drawMeteor(t: number) {
    if (!meteor && t > nextMeteorAt) {
      const angle = Math.PI * (0.65 + Math.random() * 0.2); // 大致向左下
      const speed = 9 + Math.random() * 5;
      meteor = {
        x: w * (0.3 + Math.random() * 0.6),
        y: h * Math.random() * 0.3,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed * -1,
        life: 0,
      };
    }
    if (!meteor) return;

    meteor.life += 0.02;
    meteor.x += meteor.vx;
    meteor.y += meteor.vy;

    const fade = Math.sin(Math.min(meteor.life, 1) * Math.PI); // 渐入渐出
    const tail = 14;
    const grad = ctx.createLinearGradient(
      meteor.x,
      meteor.y,
      meteor.x - meteor.vx * tail,
      meteor.y - meteor.vy * tail
    );
    grad.addColorStop(0, `rgba(232, 237, 245, ${0.85 * fade})`);
    grad.addColorStop(1, 'rgba(232, 237, 245, 0)');
    ctx.strokeStyle = grad;
    ctx.lineWidth = 1.2;
    ctx.beginPath();
    ctx.moveTo(meteor.x, meteor.y);
    ctx.lineTo(meteor.x - meteor.vx * tail, meteor.y - meteor.vy * tail);
    ctx.stroke();

    if (meteor.life >= 1 || meteor.x < -50 || meteor.y > h + 50) {
      meteor = null;
      nextMeteorAt = t + 8000 + Math.random() * 12000;
    }
  }

  function draw(t: number) {
    ctx.clearRect(0, 0, w, h);
    for (const s of stars) {
      const tw = reduced ? 1 : 0.72 + 0.28 * Math.sin(t * 0.0011 + s.phase);
      ctx.globalAlpha = s.base * tw;
      ctx.fillStyle = s.r > 1.2 ? '#cfe4ff' : '#e8edf5';
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();

      if (!reduced) {
        s.y -= s.speed; // 缓慢向上漂移，似航行
        if (s.y < -2) {
          s.y = h + 2;
          s.x = Math.random() * w;
        }
      }
    }
    ctx.globalAlpha = 1;
    if (!reduced) drawMeteor(t);
  }

  let raf = 0;
  function loop(t: number) {
    draw(t);
    raf = requestAnimationFrame(loop);
  }

  setup();
  if (reduced) {
    draw(0);
  } else {
    raf = requestAnimationFrame(loop);
    // 页面不可见时暂停，省电
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cancelAnimationFrame(raf);
      } else {
        raf = requestAnimationFrame(loop);
      }
    });
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      setup();
      if (reduced) draw(0);
    }, 150);
  });
</script>
