---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

type Lang = 'zh' | 'en';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const p = (route: string) => (lang === 'zh' ? route : '/en' + route);

const T = {
  zh: {
    title: '大海 · Ocean — airdb.space',
    desc: '从海平面到万米深渊的下潜叙事：阳光层、暮光层、午夜层、深渊层、超深渊层，蛟龙号与奋斗者号的中国深度。',
    kicker: '02 // OCEAN · DIVE LOG',
    h1: '大海',
    heroText:
      '星辰大海，一半在海。离我们最近的未知宇宙不在头顶，而在脚下 —— 往下一万米，人类去过的次数屈指可数。现在，开始下潜。',
    legend: [
      { cls: 'text-deepsea', label: '◦ BIO 深海生命' },
      { cls: 'text-silver', label: '◦ HUMAN 人类抵达' },
      { cls: 'text-ion', label: '◦ CN 中国深潜' },
    ],
    seaLevel: 'SEA LEVEL · 0 M · 下潜',
    zones: [
      { id: 'sunlight', no: 'ZONE 1', name: '阳光层', en: 'SUNLIGHT ZONE', range: '0 — 200 M', blurb: '光合作用维持的表层。海洋绝大多数的生命聚集于此，而它只是海洋极薄的一层皮肤。' },
      { id: 'twilight', no: 'ZONE 2', name: '暮光层', en: 'TWILIGHT ZONE', range: '200 — 1,000 M', blurb: '微光渐灭，生物开始自己发光。人类肉身的极限，也停在这一层。' },
      { id: 'midnight', no: 'ZONE 3', name: '午夜层', en: 'MIDNIGHT ZONE', range: '1,000 — 4,000 M', blurb: '永夜从这里开始。这一层的居民从未见过太阳，热液喷口养活着不需要阳光的生命。' },
      { id: 'abyss', no: 'ZONE 4', name: '深渊层', en: 'ABYSSAL ZONE', range: '4,000 — 6,000 M', blurb: '接近冰点、一片漆黑的平原 —— 却是地球上最辽阔的栖息地。' },
      { id: 'hadal', no: 'ZONE 5', name: '超深渊层', en: 'HADAL ZONE', range: '6,000 — 10,935 M', blurb: '只有海沟能抵达的深度。全海深，是深潜技术的珠穆朗玛。' },
    ],
    endKicker: 'CHALLENGER DEEP // −10,935 M',
    endTitleA: '这里是海洋的最深处。',
    endTitleB: '再往下，没有路 —— 但向上，全是星辰。',
    ctaSpace: '上浮，去星辰 →',
    ctaJourney: '我们的航行日志 →',
  },
  en: {
    title: 'Ocean — airdb.space',
    desc: 'A scroll-driven dive from sea level to the hadal deep: sunlight, twilight, midnight, abyssal and hadal zones — with Jiaolong and Fendouzhe marking China’s depth.',
    kicker: '02 // OCEAN · DIVE LOG',
    h1: 'Ocean',
    heroText:
      'Half of “the stars and the sea” is the sea. The nearest unknown universe is not overhead — it is beneath your feet. Ten thousand meters down, humanity has been only a handful of times. Now, dive.',
    legend: [
      { cls: 'text-deepsea', label: '◦ BIO DEEP-SEA LIFE' },
      { cls: 'text-silver', label: '◦ HUMAN REACHED' },
      { cls: 'text-ion', label: '◦ CN CHINA DIVES' },
    ],
    seaLevel: 'SEA LEVEL · 0 M · DIVE',
    zones: [
      { id: 'sunlight', no: 'ZONE 1', name: 'Sunlight Zone', en: '阳光层', range: '0 — 200 M', blurb: 'The sunlit skin of the ocean. Most marine life crowds into this thin surface layer.' },
      { id: 'twilight', no: 'ZONE 2', name: 'Twilight Zone', en: '暮光层', range: '200 — 1,000 M', blurb: 'Light fails; creatures make their own. The unaided human body reaches its limit here.' },
      { id: 'midnight', no: 'ZONE 3', name: 'Midnight Zone', en: '午夜层', range: '1,000 — 4,000 M', blurb: 'Eternal night begins. Residents here have never seen the sun; hydrothermal vents feed life that needs none.' },
      { id: 'abyss', no: 'ZONE 4', name: 'Abyssal Zone', en: '深渊层', range: '4,000 — 6,000 M', blurb: 'Near-freezing, pitch-black plains — yet the most expansive habitat on Earth.' },
      { id: 'hadal', no: 'ZONE 5', name: 'Hadal Zone', en: '超深渊层', range: '6,000 — 10,935 M', blurb: 'Depths only trenches reach. Full ocean depth is the Everest of deep-sea engineering.' },
    ],
    endKicker: 'CHALLENGER DEEP // −10,935 M',
    endTitleA: 'This is the deepest point of the ocean.',
    endTitleB: 'No way further down — but straight up, it’s all stars.',
    ctaSpace: 'Surface, to the stars →',
    ctaJourney: 'Our voyage log →',
  },
}[lang];

const all = (await getCollection('ocean-milestones')).sort(
  (a, b) => a.data.order - b.data.order
);
const byZone = (id: string) => all.filter((m) => m.data.zone === id);
const loc = (m: (typeof all)[number]) => ({
  title: lang === 'zh' ? m.data.title : m.data.titleEn,
  desc: lang === 'zh' ? m.data.desc : m.data.descEn,
});

const tagStyle = {
  BIO: 'text-deepsea border-deepsea/40',
  HUMAN: 'text-silver border-silver/30',
  CN: 'text-ion border-ion/40',
} as const;

const dotStyle = {
  BIO: 'bg-deepsea group-hover:shadow-[0_0_12px_2px_rgba(45,212,191,0.5)]',
  HUMAN: 'bg-silver group-hover:shadow-[0_0_12px_2px_rgba(154,167,189,0.5)]',
  CN: 'bg-ion group-hover:shadow-[0_0_12px_2px_rgba(77,184,255,0.5)]',
} as const;
---

<Layout lang={lang} path="/ocean" title={T.title} description={T.desc}>
  <!-- ============ HERO · 海平面 ============ -->
  <section class="relative flex h-[80svh] min-h-[560px] items-center overflow-hidden">
    <div class="hero-photo hero-photo--ocean absolute inset-y-0 right-0 w-full md:w-[68%]">
      <img src="/images/ocean/marine-biotech-research.png" alt="海洋生物科技研究实验室" class="h-full w-full object-cover" fetchpriority="high" />
    </div>
    <div class="pointer-events-none absolute inset-x-0 top-0 h-[60vh] bg-gradient-to-b from-deepsea/10 to-transparent"></div>
    <div class="pointer-events-none absolute left-1/3 top-0 h-[40vh] w-[50vw] -translate-x-1/2 rounded-full bg-deepsea/10 blur-[120px]"></div>

    <div class="relative z-10 mx-auto w-full max-w-7xl px-6 md:px-10">
      <p class="kicker rise" style="--rise-delay: 0.1s">{T.kicker}</p>
      <h1 class="headline-cn rise mt-6 text-5xl text-star md:text-7xl" style="--rise-delay: 0.3s">
        {T.h1}
      </h1>
      <p class="rise mt-8 max-w-xl text-sm leading-loose tracking-wider text-silver md:text-base" style="--rise-delay: 0.6s">
        {T.heroText}
      </p>
      <div class="rise mt-10 flex flex-wrap gap-6 font-mono text-[0.65rem] tracking-[0.25em]" style="--rise-delay: 0.9s">
        {T.legend.map((l) => <span class={l.cls}>{l.label}</span>)}
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2 rise" style="--rise-delay: 1.2s">
      <div class="scroll-cue flex flex-col items-center gap-2">
        <span class="font-mono text-[0.6rem] tracking-[0.35em] text-dim">{T.seaLevel}</span>
        <span class="block h-8 w-px bg-gradient-to-b from-deepsea/70 to-transparent"></span>
      </div>
    </div>
  </section>

  <!-- ============ 深度计（滚动时固定显示）============ -->
  <div
    id="depth-gauge"
    class="pointer-events-none fixed right-6 top-1/2 z-40 hidden -translate-y-1/2 flex-col items-end gap-1 opacity-0 transition-opacity duration-700 md:flex"
    aria-hidden="true"
  >
    <span class="font-mono text-[0.55rem] tracking-[0.35em] text-dim">DEPTH</span>
    <span class="font-display text-3xl tracking-wider text-star">
      −<span id="gauge-depth">0</span>
    </span>
    <span class="font-mono text-[0.55rem] tracking-[0.35em] text-dim">METERS</span>
    <span id="gauge-zone" class="mt-2 font-mono text-[0.6rem] tracking-[0.3em] text-deepsea"></span>
  </div>

  <!-- ============ 下潜区 ============ -->
  <section id="dive" class="relative">
    <!-- 随深度变暗的水体 -->
    <div
      class="pointer-events-none absolute inset-0"
      style="background: linear-gradient(to bottom, #0a3540 0%, #07273a 18%, #041a2e 42%, #030e1c 68%, #01060d 100%);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-7xl px-6 pb-32 md:px-10">
      <figure class="media-frame reveal relative top-12 mb-16 ml-auto aspect-[16/7] max-w-5xl overflow-hidden border-deepsea/20">
        <img src="/images/ocean/marine-biotech-research.png" alt="从环境样本到海洋生物数据分析" loading="lazy" class="h-full w-full object-cover" />
      </figure>
      {
        T.zones.map((z) => (
          <div>
            <div class="reveal pt-28 md:grid md:grid-cols-[240px_1fr] md:gap-12 md:pt-40">
              <div>
                <p class="kicker">{z.no} // {z.range}</p>
                <h2 class="headline-cn mt-4 text-3xl text-star md:text-4xl">{z.name}</h2>
                <p class="mt-2 font-display text-[0.6rem] tracking-[0.35em] text-dim">{z.en}</p>
              </div>
              <p class="mt-6 max-w-lg self-end text-sm leading-loose text-silver md:mt-0">
                {z.blurb}
              </p>
            </div>

            <div class="mt-12 border-l border-white/10 md:ml-[110px]">
              {byZone(z.id).map((m, i) => (
                <article
                  class="reveal group relative py-8 pl-8 transition-colors duration-500 hover:bg-white/[0.02] md:grid md:grid-cols-[170px_1fr] md:gap-10 md:pl-12"
                  style={`--reveal-delay: ${Math.min(i * 0.08, 0.4)}s`}
                  data-depth={m.data.depth}
                >
                  <span
                    class:list={[
                      'absolute -left-[3.5px] top-[3.1rem] h-[7px] w-[7px] rounded-full transition-all duration-500',
                      dotStyle[m.data.tag],
                    ]}
                  />
                  <p class="font-display text-xl tracking-wider text-star md:text-right md:text-2xl">
                    −{Number(m.data.depth).toLocaleString()}<span class="ml-1 text-xs text-dim">M</span>
                  </p>
                  <div class="mt-3 md:mt-1">
                    <div class="flex flex-wrap items-center gap-4">
                      <h3 class="text-lg tracking-wider text-star">{loc(m).title}</h3>
                      <span
                        class:list={[
                          'border px-2 py-0.5 font-mono text-[0.55rem] tracking-[0.25em]',
                          tagStyle[m.data.tag],
                        ]}
                      >
                        {m.data.tag}
                      </span>
                    </div>
                    <p class="mt-2 max-w-xl text-sm leading-relaxed text-silver">{loc(m).desc}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))
      }

      <!-- 海底 -->
      <div class="reveal mt-28 border border-deepsea/20 p-10 text-center md:p-16">
        <p class="kicker">{T.endKicker}</p>
        <p class="headline-cn mt-6 text-xl text-star md:text-2xl">
          {T.endTitleA}<br />{T.endTitleB}
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <a
            href={p('/space')}
            class="border border-white/10 px-8 py-3 font-mono text-xs tracking-[0.3em] text-silver transition-all duration-500 hover:border-ion/50 hover:text-ion"
          >
            {T.ctaSpace}
          </a>
          <a
            href={p('/journey')}
            class="border border-white/10 px-8 py-3 font-mono text-xs tracking-[0.3em] text-silver transition-all duration-500 hover:border-deepsea/50 hover:text-deepsea"
          >
            {T.ctaJourney}
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    // 深度计：以每条里程碑为锚点做分段插值，读数与身边的内容保持一致
    const dive = document.getElementById('dive')!;
    const gauge = document.getElementById('depth-gauge')!;
    const depthEl = document.getElementById('gauge-depth')!;
    const zoneEl = document.getElementById('gauge-zone')!;
    const MAX_DEPTH = 10935;

    const zoneName = (d: number) =>
      d < 200 ? '阳光层 SUNLIGHT'
      : d < 1000 ? '暮光层 TWILIGHT'
      : d < 4000 ? '午夜层 MIDNIGHT'
      : d < 6000 ? '深渊层 ABYSSAL'
      : '超深渊层 HADAL';

    // 锚点表：[页面 Y 坐标, 深度]，首尾补上海平面与海底
    let anchors: [number, number][] = [];
    function buildAnchors() {
      const top = dive.getBoundingClientRect().top + window.scrollY;
      anchors = [[top, 0]];
      dive.querySelectorAll<HTMLElement>('[data-depth]').forEach((el) => {
        const r = el.getBoundingClientRect();
        anchors.push([r.top + window.scrollY + r.height / 2, Number(el.dataset.depth)]);
      });
      anchors.push([top + dive.offsetHeight, MAX_DEPTH]);
    }

    let ticking = false;
    function update() {
      ticking = false;
      const rect = dive.getBoundingClientRect();
      const anchorY = window.scrollY + window.innerHeight * 0.5;
      const progress = (window.innerHeight * 0.5 - rect.top) / rect.height;

      if (progress <= 0 || progress >= 1.05) {
        gauge.style.opacity = '0';
        return;
      }
      gauge.style.opacity = '1';

      let depth = MAX_DEPTH;
      for (let i = 1; i < anchors.length; i++) {
        const [y1, d1] = anchors[i - 1];
        const [y2, d2] = anchors[i];
        if (anchorY <= y2) {
          const t = Math.max(0, Math.min(1, (anchorY - y1) / (y2 - y1)));
          depth = Math.round(d1 + t * (d2 - d1));
          break;
        }
      }
      depthEl.textContent = depth.toLocaleString();
      zoneEl.textContent = zoneName(depth);
    }

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    buildAnchors();
    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        buildAnchors();
        update();
      }, 150);
    });
    // 字体加载完成后重新测量一次，防止锚点漂移
    window.addEventListener('load', () => {
      buildAnchors();
      update();
    });
  </script>
</Layout>
