---
import '../styles/global.css';
import '@fontsource/michroma';
import '@fontsource/ibm-plex-sans/300.css';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-mono/400.css';

type Lang = 'zh' | 'en';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  /** 不带语言前缀的路径，如 '/'、'/space'，用于 canonical / hreflang / 语言切换 */
  path?: string;
}

const SITE = 'https://airdb.space';

const {
  lang = 'zh',
  path = '/',
  title = lang === 'zh' ? 'airdb.space — 星辰大海' : 'airdb.space — To the Stars, Into the Deep',
  description = lang === 'zh'
    ? '我们的征途是星辰大海。To the stars, and into the deep. 航空航天 · 深海科技 · AI 科技积累。'
    : 'Our voyage is to the stars and the deep sea. Aerospace, deep-sea exploration, and the AI engineering behind it.',
} = Astro.props;

const zhUrl = SITE + path;
const enUrl = SITE + '/en' + (path === '/' ? '/' : path);
const canonical = lang === 'zh' ? zhUrl : enUrl;
const switchHref = lang === 'zh' ? '/en' + (path === '/' ? '/' : path) : path;
const home = lang === 'zh' ? '/' : '/en/';
const p = (route: string) => (lang === 'zh' ? route : '/en' + route);

const nav =
  lang === 'zh'
    ? [
        { href: p('/space'), label: '星辰', sub: 'Space' },
        { href: p('/ocean'), label: '大海', sub: 'Ocean' },
        { href: p('/technology'), label: '科技', sub: 'Technology' },
        { href: p('/journey'), label: '历程', sub: 'Journey' },
      ]
    : [
        { href: p('/space'), label: 'Space', sub: '星辰' },
        { href: p('/ocean'), label: 'Ocean', sub: '大海' },
        { href: p('/technology'), label: 'Technology', sub: '科技' },
        { href: p('/journey'), label: 'Journey', sub: '历程' },
      ];

const F =
  lang === 'zh'
    ? {
        headline: '每一步，都走得稳一些。',
        mono: 'STEP BY STEP, TOWARD THE STARS AND THE DEEP.',
        links: [
          { href: p('/space'), label: '星辰 / SPACE', hover: 'hover:text-ion' },
          { href: p('/ocean'), label: '大海 / OCEAN', hover: 'hover:text-deepsea' },
          { href: p('/technology'), label: '科技 / TECH', hover: 'hover:text-ion' },
          { href: p('/journey'), label: '历程 / JOURNEY', hover: 'hover:text-star' },
          { href: p('/about'), label: '关于 / ABOUT', hover: 'hover:text-star' },
        ],
        copyright: '我们的征途是星辰大海',
      }
    : {
        headline: 'Every step, taken steadily.',
        mono: '每一步，都走得稳一些。',
        links: [
          { href: p('/space'), label: 'SPACE / 星辰', hover: 'hover:text-ion' },
          { href: p('/ocean'), label: 'OCEAN / 大海', hover: 'hover:text-deepsea' },
          { href: p('/technology'), label: 'TECH / 科技', hover: 'hover:text-ion' },
          { href: p('/journey'), label: 'JOURNEY / 历程', hover: 'hover:text-star' },
          { href: p('/about'), label: 'ABOUT / 关于', hover: 'hover:text-star' },
        ],
        copyright: 'TO THE STARS AND THE DEEP SEA',
      };
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:site_name" content="airdb.space" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE}/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE}/og.png`} />
  </head>
  <body>
    <header class="fixed top-0 left-0 right-0 z-50 bg-space/70 backdrop-blur-md">
      <div
        class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 md:px-10"
      >
        <a href={home} class="group flex items-baseline gap-3">
          <span class="font-display text-sm tracking-[0.3em] text-star"
            >AIRDB</span
          >
          <span
            class="font-mono text-[0.65rem] tracking-[0.25em] text-dim transition-colors group-hover:text-ion"
            >.SPACE</span
          >
        </a>
        <nav class="flex items-center gap-5 md:gap-9">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class="group flex items-baseline gap-2 text-sm text-silver transition-colors hover:text-star"
              >
                <span class="tracking-[0.2em]">{item.label}</span>
                <span class="hidden font-mono text-[0.6rem] uppercase tracking-[0.2em] text-dim transition-colors group-hover:text-ion lg:inline">
                  {item.sub}
                </span>
              </a>
            ))
          }
          <a
            href={switchHref}
            class="border border-white/15 px-2.5 py-1 font-mono text-[0.65rem] tracking-[0.2em] text-silver transition-all hover:border-ion/50 hover:text-ion"
            aria-label={lang === 'zh' ? 'Switch to English' : '切换到中文'}
          >
            {lang === 'zh' ? 'EN' : '中'}
          </a>
        </nav>
      </div>
      <div class="hairline"></div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="relative border-t border-white/5 bg-void">
      <div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
        <p class="headline-cn text-lg text-silver md:text-xl">
          {F.headline}
        </p>
        <p class="mt-3 font-mono text-xs tracking-[0.3em] text-dim">
          {F.mono}
        </p>

        <div class="mt-12 flex flex-col justify-between gap-6 md:flex-row md:items-end">
          <div class="flex flex-wrap gap-x-8 gap-y-3 font-mono text-xs tracking-[0.2em] text-dim">
            {
              F.links.map((l) => (
                <a href={l.href} class:list={['transition-colors', l.hover]}>
                  {l.label}
                </a>
              ))
            }
            <a
              href="https://github.com/airdb"
              target="_blank"
              rel="noopener"
              class="transition-colors hover:text-star">GITHUB ↗</a
            >
            <a
              href="mailto:info@airdb.com"
              class="transition-colors hover:text-ion">INFO@AIRDB.COM</a
            >
          </div>
          <p class="font-mono text-[0.65rem] tracking-[0.2em] text-dim">
            © {new Date().getFullYear()} AIRDB.SPACE — {F.copyright}
          </p>
        </div>
      </div>
    </footer>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
